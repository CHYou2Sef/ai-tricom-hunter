# ╔══════════════════════════════════════════════════════════════════╗
# ║  AI Tricom Hunter — Professional Environment Template (V5)       ║
# ║  Optimized for Windows Host (HDD) + Docker Linux Container       ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── 🏗️ INFRASTRUCTURE & PATHS ──────────────────────────────────────
# HOST_WORK_DIR: Absolute path on your WINDOWS machine (e.g. C:/Data/AI_Hunter/WORK)
# This folder will be "teleported" into the container's /app/WORK
HOST_WORK_DIR=./WORK
HOST_LOG_DIR=./logs

# Inside Docker, leave these as defaults (/app/WORK, /app/logs)
WORK_DIR=/app/WORK
LOG_DIR=/app/logs

# ── 🏎️ HARDWARE OPTIMIZATION (Crucial for HDD/8GB RAM) ───────────
# Save frequency (total rows processed before writing to HDD).
# Higher = Less HDD stress, but more RAM usage. 50-100 is best for HDDs.
SAVE_INTERVAL=50

# Max workers. On 8GB RAM, strictly keep this at 1 or 2.
MAX_CONCURRENT_WORKERS=1

# ── 🌐 BROWSER STEALTH & TIERS ────────────────────────────────────
# Tier selection (1=Patchright, 2=Nodriver, 3=Crawl4AI, 4=Camoufox)
HYBRID_DEFAULT_TIER=1

# Enable/Disable engines to save RAM
SELENIUM_ENABLED=false
CAMOUFOX_ENABLED=false

# ── Performance & Tier Complexity ──
# PERFORMANCE_MODE:
#   "simple"   → [2, 3] (SeleniumBase + Botasaurus).
#   "stealth"  → [2, 5] (SeleniumBase + Nodriver).
#   "balanced" → [2, 3, 4] (SeleniumBase + Botasaurus + Patchright).
#   "full"     → [2, 5, 4, 6] (GOLDEN PATH: SB + Nodriver + Cloak + Crawl4AI).
PERFORMANCE_MODE=full
MAX_WATERFALL_TIER=10

# ── 🗝️ CREDENTIALS & API KEYS ───────────────────────────────────
# Optional: CAPTCHA Auto-Solver (2captcha | capsolver | manual)
CAPTCHA_SOLVER=manual
CAPTCHA_API_KEY=

# ── 🤖 AI SEARCH LOGIC ──────────────────────────────────────────
# Prompt style: 'caveman' (recommended for speed/tokens) | 'verbose'
PROMPT_STYLE=caveman

# Local LLM (Ollama) configuration
OLLAMA_ENABLED=true
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT=60

# ── 📝 LOGGING & RECOVERY ────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Set to false to avoid double-processing correctly finished rows
REPROCESS_FAILED_ROWS=true